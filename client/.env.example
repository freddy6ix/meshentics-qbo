# Copy to client/.env (gitignored) and fill from your Intuit Developer app.
# NEVER commit the real .env — it holds secrets (charter §6).

QBO_ENVIRONMENT=sandbox          # 'sandbox' while testing, 'production' for the real company
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:8000/callback   # must match a Redirect URI registered in your Intuit app
QBO_REALM_ID=                    # company id; auto-filled after `exchange`, or set manually

# Optional bootstrap: paste a refresh token (e.g., from Intuit's OAuth 2.0 Playground)
# instead of running the authurl/exchange flow.
QBO_REFRESH_TOKEN=
